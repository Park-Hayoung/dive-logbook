{
  "expo": {
    "name": "DiveLog",
    "slug": "divelog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "divelog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.woozoo.divelog",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "다이브 컴퓨터(Shearwater)와 연결하여 다이브 로그를 가져옵니다.",
        "NSPhotoLibraryUsageDescription": "다이브 로그에 사진을 첨부하기 위해 갤러리 접근이 필요합니다.",
        "NSCameraUsageDescription": "자격증 카드(C-card) 촬영을 위해 카메라가 필요합니다.",
        "NSLocationWhenInUseUsageDescription": "다이브 위치를 자동으로 채우기 위해 현재 위치가 필요합니다."
      }
    },
    "android": {
      "package": "com.woozoo.divelog",
      "adaptiveIcon": {
        "backgroundColor": "#0066FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBpXBi8LB1f6xhdk089JmPxKuz0ouywmSc"
        }
      },
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "다이브 컴퓨터와 통신하기 위해 Bluetooth가 필요합니다."
        }
      ],
      "expo-build-properties",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/KCCDodamdodam.ttf"]
        }
      ],
      "react-native-compressor",
      [
        "expo-camera",
        {
          "cameraPermission": "자격증 카드 촬영을 위해 카메라가 필요합니다."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "다이브 위치를 자동으로 채우기 위해 현재 위치가 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ce50da32-1e82-4bfb-b0e4-dde9171b5ed3"
      }
    }
  }
}

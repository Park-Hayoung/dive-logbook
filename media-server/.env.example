# Port the Hono server listens on (inside container)
PORT=3000

# Filesystem path where media is written.
# In Docker, mount /volume1/divelog-media → /data
STORAGE_ROOT=/data

# Public base URL where files are served (Cloudflare Tunnel hostname).
# Files will be accessible at ${PUBLIC_BASE_URL}/file/...
PUBLIC_BASE_URL=https://media.dooname.cloud

# Supabase JWT secret — used to verify auth tokens from the mobile app.
# Find at: Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# HMAC secret for signing short-lived upload URLs.
# Generate with: openssl rand -hex 32
UPLOAD_HMAC_SECRET=

# Upload URL TTL (seconds). Default 15 minutes.
UPLOAD_URL_TTL=900

# Max upload size (bytes). Default 2GB.
MAX_UPLOAD_BYTES=2147483648

# Cloudflare Tunnel token (from Cloudflare Zero Trust → Networks → Tunnels →
# select tunnel → Install connector tab). Used by docker-compose only.
CLOUDFLARE_TUNNEL_TOKEN=

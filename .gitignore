# Dive data (binary output, not version controlled)
logbook/data/

# External C library (protocol reference, obtain separately)
libdivecomputer/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node (any subproject)
node_modules/

# Expo auto-generated dev state (any subproject)
.expo/

# Supabase CLI cache (linked-project, cli-latest) — match any depth
**/supabase/.temp/

# Build outputs
dist/
build/

# Environment files (root + subprojects)
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
.DS_Store

# Playwright MCP cache
.playwright-mcp/

# OS
Thumbs.db

# Firebase Admin SDK service account key — never commit
*-firebase-adminsdk-*.json
